# =============================================================================
# ML Portal Rerank Service - Production Dockerfile
# =============================================================================

ARG BASE_IMAGE=ml-portal-base-ml:v1

FROM ${BASE_IMAGE} AS dependencies

USER root
WORKDIR /app
COPY infra/docker/rerank/requirements.txt /tmp/requirements.rerank.txt
RUN python -m pip install --no-cache-dir -r /tmp/requirements.rerank.txt

FROM ${BASE_IMAGE} AS production

USER root
WORKDIR /app
COPY --from=dependencies /usr/local/lib/python3.11/site-packages /usr/local/lib/python3.11/site-packages
COPY --from=dependencies /usr/local/bin /usr/local/bin
COPY --chown=appuser:appuser apps/rerank/src/app/ /app/

ENV PYTHONPATH=/app \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    RERANK_MODEL_PATH=/models_llm/cross-encoder--ms-marco-MiniLM-L-6-v2

USER appuser

EXPOSE 8002

HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD curl -f http://localhost:8002/health || exit 1

CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8002", "--workers", "2"]
