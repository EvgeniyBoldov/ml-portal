# =============================================================================
# ML Portal Embedding Service - Production Dockerfile
# =============================================================================

ARG BASE_IMAGE=ml-portal-base-ml:v1

FROM ${BASE_IMAGE} AS dependencies

USER root

WORKDIR /app
COPY infra/docker/emb/requirements.txt /tmp/requirements.emb.txt
RUN python -m pip install --no-cache-dir -r /tmp/requirements.emb.txt

FROM ${BASE_IMAGE} AS production

USER root
WORKDIR /app
COPY --from=dependencies /usr/local/lib/python3.11/site-packages /usr/local/lib/python3.11/site-packages
COPY --from=dependencies /usr/local/bin /usr/local/bin
COPY --chown=appuser:appuser apps/emb/src/app/ /app/

# Set environment variables
ENV PYTHONPATH=/app \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    EMB_MODEL_ALIAS="all-MiniLM-L6-v2" \
    EMB_MODEL_PATH="/models_llm/sentence-transformers--all-MiniLM-L6-v2" \
    EMB_MODEL_DIMENSIONS=384 \
    EMB_MODEL_MAX_TOKENS=512 \
    EMB_MODEL_VERSION="1.0" \
    EMB_MODEL_PARALLELISM=2 \
    EMB_BATCH_SIZE=128 \
    EMB_MAX_WAIT_MS=8

# Switch to non-root user
USER appuser

# Expose port
EXPOSE 8001

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD curl -f http://localhost:8001/health || exit 1

# Start command (production with multiple workers)
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8001", "--workers", "2"]
