# =============================================================================
# ML Portal Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values as needed
# All values below are defaults for Docker development environment

# =============================================================================
# GENERAL APPLICATION SETTINGS
# =============================================================================
# Environment and debug mode
ENV=local
DEBUG=true

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL database settings
DATABASE_URL=postgresql://ml_portal:ml_portal_password@postgres:5432/ml_portal
DB_URL=postgresql://ml_portal:ml_portal_password@postgres:5432/ml_portal
ASYNC_DB_URL=postgresql+asyncpg://ml_portal:ml_portal_password@postgres:5432/ml_portal
POSTGRES_DB=ml_portal
POSTGRES_USER=ml_portal
POSTGRES_PASSWORD=ml_portal_password

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
# Redis URL for caching, sessions, and idempotency
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================
# JWT secrets (CHANGE IN PRODUCTION!)
JWT_SECRET=change-me-change-me-change-me-change-me-change-me-change-me-change-me-change-me-change-me-change-me-change-me-change-me-change-me-change-me-change-me
JWT_ALGORITHM=HS256
JWT_ISSUER=urn:ml-portal
JWT_AUDIENCE=urn:ml-portal:api
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30
JWT_JWKS_JSON=
JWT_KID=

# Personal Access Tokens
PAT_ENABLED=true

# =============================================================================
# PASSWORD POLICY
# =============================================================================
PASSWORD_MIN_LENGTH=10
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGITS=true
PASSWORD_REQUIRE_SPECIAL=false
PASSWORD_PEPPER=

# =============================================================================
# LLM CONFIGURATION (Universal - supports any OpenAI-compatible API)
# =============================================================================
# Supported providers: openai, groq, azure, anthropic, local, vllm, ollama, etc.
# Provider name (for logging/monitoring)
LLM_PROVIDER=groq

# OpenAI-compatible API endpoint
# Examples:
#   - Groq: https://api.groq.com/openai/v1
#   - OpenAI: https://api.openai.com/v1
#   - Azure: https://your-resource.openai.azure.com/openai/deployments/your-deployment
#   - Local vLLM: http://localhost:8000/v1
#   - Ollama: http://localhost:11434/v1
LLM_BASE_URL=https://api.groq.com/openai/v1

# API key for authentication
LLM_API_KEY=your-api-key-here

# Default model to use
# Examples:
#   - Groq: llama-3.1-8b-instant, llama-3.1-70b-versatile, mixtral-8x7b-32768
#   - OpenAI: gpt-4-turbo-preview, gpt-3.5-turbo
#   - Local: depends on your deployment
LLM_DEFAULT_MODEL=llama-3.1-8b-instant

# Request timeout in seconds
LLM_TIMEOUT=30

# Legacy variables (deprecated, will be removed in future versions)
# GROQ_API_KEY=...  # Use LLM_API_KEY instead
# LLM_TOKEN=...     # Use LLM_API_KEY instead

# =============================================================================
# EMBEDDING MODELS CONFIGURATION
# =============================================================================
# Comma-separated list of embedding model aliases
EMB_MODELS=all-MiniLM-L6-v2,multilingual-e5-small,bge-large-en

# Paths to model files (one per model)
EMB_MODEL_all-MiniLM-L6-v2_PATH=/models_llm/sentence-transformers--all-MiniLM-L6-v2
EMB_MODEL_multilingual-e5-small_PATH=/models_llm/multilingual-e5-small
EMB_MODEL_bge-large-en_PATH=/models_llm/bge-large-en

# Embedding service configuration
EMB_BASE_URL=http://emb:8001
EMB_BATCH_SIZE=128
EMB_MAX_WAIT_MS=8
EMB_PARALLELISM_all-MiniLM-L6-v2=2
EMB_PARALLELISM_multilingual-e5-small=2
EMB_PARALLELISM_bge-large-en=1

# HTTP Configuration
HTTP_TIMEOUT_SECONDS=30
HTTP_MAX_RETRIES=2
TIMEOUT_SECONDS=30

# Circuit Breaker Configuration
CB_LLM_FAILURES_THRESHOLD=5
CB_LLM_OPEN_TIMEOUT_SECONDS=30.0
CB_LLM_HALF_OPEN_MAX_CALLS=1
CB_EMB_FAILURES_THRESHOLD=5
CB_EMB_OPEN_TIMEOUT_SECONDS=30.0
CB_EMB_HALF_OPEN_MAX_CALLS=1

# =============================================================================
# MINIO/S3 STORAGE CONFIGURATION
# =============================================================================
# MinIO S3-compatible storage settings
S3_ENDPOINT=minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_SECURE=false
S3_BUCKET_RAG=rag
S3_BUCKET_ARTIFACTS=artifacts
UPLOAD_MAX_BYTES=104857600
UPLOAD_ALLOWED_MIME=application/pdf,image/png,image/jpeg,application/octet-stream

# Public file access configuration
PUBLIC_FILES_HOST=files.localhost
MINIO_ENDPOINT_INTERNAL=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_SECURE=false
PRESIGNED_TTL_SECONDS=60
MINIO_BUCKET_DEFAULT=rag

# =============================================================================
# QDRANT VECTOR DATABASE
# =============================================================================
# Qdrant vector database for embeddings
QDRANT_URL=http://qdrant:6333

# =============================================================================
# MODEL REGISTRY CONFIGURATION
# =============================================================================
# Path to models directory for auto-scanning
MODELS_ROOT=/models_llm

# =============================================================================
# IDEMPOTENCY CONFIGURATION
# =============================================================================
# Idempotency key handling
IDEMPOTENCY_ENABLED=true
IDEMP_TTL_HOURS=24
IDEMPOTENCY_MAX_BYTES=1048576

# =============================================================================
# CELERY WORKER CONFIGURATION
# =============================================================================
# Celery task queue settings
BEAT=0

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
# Cross-Origin Resource Sharing settings
CORS_ALLOW_ORIGINS=*

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================
# Frontend application settings
VITE_API_BASE_URL=http://localhost:8000
VITE_APP_NAME=ML Portal
NEXT_PUBLIC_API_URL=http://localhost:8000

# =============================================================================
# NGINX CONFIGURATION
# =============================================================================
# Nginx reverse proxy settings
NGINX_PORT_HTTP=80
NGINX_PORT_HTTPS=443
NGINX_CLIENT_MAX_BODY_SIZE=100M
NGINX_PROXY_TIMEOUT=300s

# =============================================================================
# HEALTH CHECK CONFIGURATION
# =============================================================================
# Health check endpoints settings
HEALTH_CHECK_TIMEOUT=10
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_RETRIES=3
HEALTH_CHECK_START_PERIOD=40s

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
# Logging level and configuration
LOG_LEVEL=INFO

# =============================================================================
# DEVELOPMENT/TESTING OVERRIDES
# =============================================================================
# Uncomment these for development environment
# DATABASE_URL=sqlite:///./dev.db
# ASYNC_DB_URL=sqlite+aiosqlite:///./dev.db
# REDIS_URL=redis://localhost:6379/0
# QDRANT_URL=http://localhost:6333
# S3_ENDPOINT=localhost:9000
# LLM_BASE_URL=http://localhost:8002
# EMB_BASE_URL=http://localhost:8001

# =============================================================================
# PRODUCTION OVERRIDES
# =============================================================================
# Uncomment and set these for production deployment
# ENV=production
# DEBUG=false
# DATABASE_URL=postgresql://user:password@prod-db:5432/ml_portal
# REDIS_URL=redis://prod-redis:6379/0
# S3_ENDPOINT=https://your-s3-endpoint.com
# S3_ACCESS_KEY=your-production-access-key
# S3_SECRET_KEY=your-production-secret-key
# QDRANT_URL=https://your-qdrant-cluster.com
# LLM_BASE_URL=https://your-llm-service.com
# EMB_BASE_URL=https://your-embeddings-service.com
# JWT_SECRET=your-super-secure-production-jwt-secret-minimum-256-bits
# LOG_LEVEL=WARNING
# IDEMPOTENCY_ENABLED=false
# CORS_ALLOW_ORIGINS=https://your-frontend-domain.com