# =============================================================================
# ML Portal — Environment Configuration Template
# =============================================================================
# Copy to .env and fill in secrets. `.env` is gitignored.

# -----------------------------------------------------------------------------
# GENERAL
# -----------------------------------------------------------------------------
ENV=development
DEBUG=true
LOG_LEVEL=DEBUG

# -----------------------------------------------------------------------------
# POSTGRES (primary)
# -----------------------------------------------------------------------------
POSTGRES_DB=ml_portal
POSTGRES_USER=ml_portal
POSTGRES_PASSWORD=CHANGE_ME

DATABASE_URL=postgresql://ml_portal:CHANGE_ME@postgres:5432/ml_portal
ASYNC_DB_URL=postgresql+asyncpg://ml_portal:CHANGE_ME@postgres:5432/ml_portal

# -----------------------------------------------------------------------------
# POSTGRES REMOTE (demo external DB for dbhub-mcp)
# -----------------------------------------------------------------------------
REMOTE_POSTGRES_HOST=postgres-remote
REMOTE_POSTGRES_DB=demo
REMOTE_POSTGRES_USER=demo
REMOTE_POSTGRES_PASSWORD=CHANGE_ME

# -----------------------------------------------------------------------------
# REDIS / CELERY
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
BEAT=0

# -----------------------------------------------------------------------------
# AUTH (JWT) — CHANGE for production
# -----------------------------------------------------------------------------
JWT_SECRET=CHANGE_ME_TO_RANDOM_256_BITS
JWT_ALGORITHM=HS256
JWT_ISSUER=urn:ml-portal-dev
JWT_AUDIENCE=urn:ml-portal:api
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30
JWT_JWKS_JSON=
JWT_KID=
PAT_ENABLED=true

# Runtime confirmation / credentials security
CREDENTIALS_MASTER_KEY=
CONFIRMATION_SECRET=
CONFIRMATION_TTL_SECONDS=300

# -----------------------------------------------------------------------------
# PASSWORD POLICY
# -----------------------------------------------------------------------------
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=false
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGITS=true
PASSWORD_REQUIRE_SPECIAL=false
PASSWORD_PEPPER=

# -----------------------------------------------------------------------------
# LDAP AUTHENTICATION (optional)
# -----------------------------------------------------------------------------
# Master switch - if false, LDAP auth is disabled entirely
AUTH_LDAP_ENABLED=false

# LDAP server connection (example for AD without TLS)
AUTH_LDAP_SERVER_URI=ldap://1.1.1.1:389
AUTH_LDAP_BIND_DN=CN=service,OU=Users,DC=example,DC=com
AUTH_LDAP_BIND_PASSWORD=
AUTH_LDAP_USER_SEARCH_BASEDN=OU=Users,DC=example,DC=com
AUTH_LDAP_GROUP_SEARCH_BASEDN=OU=Groups,DC=example,DC=com

# Search and attribute mapping
AUTH_LDAP_USER_SEARCH_FILTER=(&(objectClass=user)(sAMAccountName={login}))
AUTH_LDAP_USER_LOGIN_ATTR=sAMAccountName
AUTH_LDAP_USER_EMAIL_ATTR=mail
AUTH_LDAP_USER_DISPLAY_NAME_ATTR=displayName
AUTH_LDAP_GROUP_MEMBER_ATTR=memberOf

# TLS settings (enable for production)
AUTH_LDAP_USE_TLS=false
AUTH_LDAP_TLS_CA_FILE=
AUTH_LDAP_TLS_VERIFY=true
AUTH_LDAP_REFERRALS=false
AUTH_LDAP_TIMEOUT_SECONDS=5

# Default tenant and role for new LDAP users
AUTH_LDAP_DEFAULT_TENANT_SLUG=default
AUTH_LDAP_DEFAULT_ROLE=reader

# Behavior flags
AUTH_LDAP_AUTO_CREATE_USERS=true
AUTH_LDAP_UPDATE_PROFILE_ON_LOGIN=true
AUTH_LDAP_SYNC_ENABLED=true
AUTH_LDAP_SYNC_CRON=30 3 * * *

# -----------------------------------------------------------------------------
# DEFAULT ADMIN
# -----------------------------------------------------------------------------
DEFAULT_ADMIN_LOGIN=admin
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_EMAIL=admin@example.com

# -----------------------------------------------------------------------------
# RUNTIME / RBAC
# -----------------------------------------------------------------------------
RUNTIME_RBAC_ENFORCE_RULES=false
RUNTIME_RBAC_ALLOW_UNDEFINED=true

# -----------------------------------------------------------------------------
# LLM (OpenAI-compatible)
# -----------------------------------------------------------------------------
LLM_TIMEOUT=30

HTTP_TIMEOUT_SECONDS=30
HTTP_MAX_RETRIES=2
TIMEOUT_SECONDS=30

CB_LLM_FAILURES_THRESHOLD=5
CB_LLM_OPEN_TIMEOUT_SECONDS=30.0
CB_LLM_HALF_OPEN_MAX_CALLS=1
CB_EMB_FAILURES_THRESHOLD=5
CB_EMB_OPEN_TIMEOUT_SECONDS=30.0
CB_EMB_HALF_OPEN_MAX_CALLS=1

# -----------------------------------------------------------------------------
# QDRANT
# -----------------------------------------------------------------------------
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# -----------------------------------------------------------------------------
# MINIO / S3
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME

S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=CHANGE_ME
S3_SECURE=false
S3_BUCKET_RAG=rag
S3_BUCKET_ARTIFACTS=artifacts

UPLOAD_MAX_BYTES=104857600
UPLOAD_ALLOWED_MIME=application/pdf,image/png,image/jpeg,application/octet-stream

# -----------------------------------------------------------------------------
# IDEMPOTENCY
# -----------------------------------------------------------------------------
IDEMPOTENCY_ENABLED=false
IDEMP_TTL_HOURS=24
IDEMPOTENCY_MAX_BYTES=1048576

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ALLOW_ORIGINS=*

# -----------------------------------------------------------------------------
# FRONTEND (Vite)
# -----------------------------------------------------------------------------
# RELATIVE path — avoids cross-origin and CORS issues.
VITE_API_BASE_URL=/api/v1
VITE_API_PROXY_TARGET=http://api:8000
VITE_APP_NAME=ML Portal Dev
VITE_APP_ENV=development
VITE_PORT=5173

# -----------------------------------------------------------------------------
# NGINX
# -----------------------------------------------------------------------------
NGINX_PORT_HTTP=80

# -----------------------------------------------------------------------------
# MCP SERVERS
# -----------------------------------------------------------------------------
NETBOX_URL=http://netbox.local
