# =============================================================================
# ML Portal — Environment Configuration
# =============================================================================
# Copy to .env and fill in your values.
# Values marked REQUIRED must be set before first run.
# Values marked PROD must be changed for production deployments.

# =============================================================================
# GENERAL
# =============================================================================
ENV=development          # local | development | production
DEBUG=true
LOG_LEVEL=DEBUG          # DEBUG | INFO | WARNING | ERROR

# =============================================================================
# DATABASE — PostgreSQL
# =============================================================================
# Credentials used both by the postgres container and the API/worker
POSTGRES_DB=ml_portal
POSTGRES_USER=ml_portal
POSTGRES_PASSWORD=ml_portal_password   # PROD: change

# Connection URLs consumed by API and worker (must match above)
DATABASE_URL=postgresql://ml_portal:ml_portal_password@postgres:5432/ml_portal
ASYNC_DB_URL=postgresql+asyncpg://ml_portal:ml_portal_password@postgres:5432/ml_portal

# =============================================================================
# REDIS
# =============================================================================
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================
JWT_SECRET=dev-jwt-secret-minimum-256-bits   # REQUIRED, PROD: generate with: openssl rand -hex 32
JWT_ALGORITHM=HS256                           # HS256 (dev) | RS256 (prod with JWT_PRIVATE_KEY)
JWT_ISSUER=urn:ml-portal
JWT_AUDIENCE=urn:ml-portal:api
JWT_ACCESS_TTL_MINUTES=1440
JWT_REFRESH_TTL_DAYS=30
# For RS256 (production): set these instead of JWT_SECRET
# JWT_PRIVATE_KEY=<PEM>
# JWT_PUBLIC_KEY=<PEM>
# JWT_KID=key-id-for-rotation

# Personal Access Tokens
PAT_ENABLED=true

# =============================================================================
# PASSWORD POLICY
# =============================================================================
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=false
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGITS=true
PASSWORD_REQUIRE_SPECIAL=false
# PASSWORD_PEPPER=                            # Optional: static pepper for password hashing

# =============================================================================
# OBJECT STORAGE — MinIO / S3-compatible
# =============================================================================
# Internal endpoint (used by API/worker inside docker network)
S3_ENDPOINT=http://minio:9000
# Public endpoint for presigned download URLs (seen by browser)
S3_PUBLIC_ENDPOINT=https://files.example.com
S3_ACCESS_KEY=minioadmin                      # PROD: change
S3_SECRET_KEY=minioadmin123                   # PROD: change
S3_SECURE=false                               # true when S3_ENDPOINT uses HTTPS
S3_BUCKET_RAG=rag
S3_BUCKET_ARTIFACTS=artifacts
S3_BUCKET_CHAT_UPLOADS=chat-uploads
UPLOAD_MAX_BYTES=104857600                    # 100 MB
UPLOAD_ALLOWED_MIME=application/pdf,image/png,image/jpeg,application/octet-stream

# MinIO container credentials (used by the minio service itself)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123             # PROD: change

# =============================================================================
# QDRANT — Vector Database
# =============================================================================
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=                               # Optional: set if Qdrant auth is enabled

# =============================================================================
# LLM — Universal OpenAI-compatible
# =============================================================================
# Provider name for logging/monitoring: openai | groq | azure | vllm | ollama | local
LLM_PROVIDER=groq
# OpenAI-compatible base URL
LLM_BASE_URL=
# REQUIRED: API key for chosen provider
LLM_API_KEY=                                  # REQUIRED
LLM_DEFAULT_MODEL=
LLM_TIMEOUT=60

# =============================================================================
# EMBEDDING SERVICE
# =============================================================================
# URL of the primary embedding service container
EMB_BASE_URL=http://emb:8001
# Model config for the emb container (override per-container in compose)
EMB_MODEL_ALIAS=all-MiniLM-L6-v2
EMB_MODEL_PATH=/models_llm/sentence-transformers--all-MiniLM-L6-v2
EMB_MODEL_DIMENSIONS=384
EMB_MODEL_MAX_TOKENS=512
EMB_MODEL_VERSION=1.0
EMB_BATCH_SIZE=128
EMB_MAX_WAIT_MS=8
EMB_MODEL_PARALLELISM=2
EMB_OFFLINE=true                              # Disallow network downloads of model weights

# =============================================================================
# RERANKER SERVICE
# =============================================================================
RERANK_SERVICE_URL=http://rerank:8002
RERANK_ENABLED=true

# =============================================================================
# CIRCUIT BREAKER
# =============================================================================
CB_LLM_FAILURES_THRESHOLD=5
CB_LLM_OPEN_TIMEOUT_SECONDS=30.0
CB_LLM_HALF_OPEN_MAX_CALLS=1
CB_EMB_FAILURES_THRESHOLD=5
CB_EMB_OPEN_TIMEOUT_SECONDS=30.0
CB_EMB_HALF_OPEN_MAX_CALLS=1

# =============================================================================
# IDEMPOTENCY
# =============================================================================
IDEMPOTENCY_ENABLED=true
IDEMP_TTL_HOURS=24
IDEMPOTENCY_MAX_BYTES=1048576

# =============================================================================
# CELERY WORKER
# =============================================================================
BEAT=0

# =============================================================================
# CORS
# =============================================================================
CORS_ALLOW_ORIGINS=*                          # PROD: set to your frontend origin(s)

# =============================================================================
# DEFAULT ADMIN (seed on first start)
# =============================================================================
DEFAULT_ADMIN_LOGIN=admin
DEFAULT_ADMIN_PASSWORD=admin123               # PROD: change
DEFAULT_ADMIN_EMAIL=admin@example.com

# =============================================================================
# CREDENTIALS ENCRYPTION
# =============================================================================
# Master key for encrypting tool credentials (Fernet).
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIALS_MASTER_KEY=                       # REQUIRED in production

# =============================================================================
# MCP CREDENTIAL BROKER
# =============================================================================
# Set to true to use short-lived broker tokens instead of raw credential injection
MCP_CREDENTIAL_BROKER_ENABLED=false
MCP_CREDENTIAL_TOKEN_TTL_SECONDS=90
MCP_CREDENTIAL_BROKER_BASE_URL=http://api:8000

# =============================================================================
# RUNTIME RBAC
# =============================================================================
RUNTIME_RBAC_ENFORCE_RULES=false
RUNTIME_RBAC_ALLOW_UNDEFINED=true

# =============================================================================
# NGINX
# =============================================================================
NGINX_PORT_HTTP=80
NGINX_CLIENT_MAX_BODY_SIZE=100M
NGINX_PROXY_TIMEOUT=300s

# =============================================================================
# EXTERNAL DATA SOURCES (demo / dev)
# =============================================================================
# Remote PostgreSQL used by SQL MCP shim (dbhub-mcp)
REMOTE_POSTGRES_DB=external_analytics
REMOTE_POSTGRES_USER=external_user
REMOTE_POSTGRES_PASSWORD=external_password    # PROD: change
REMOTE_POSTGRES_HOST=postgres-remote
REMOTE_POSTGRES_PORT=5432

# NetBox API URL (used by netbox-mcp-custom)
NETBOX_URL=http://host.docker.internal:8000
