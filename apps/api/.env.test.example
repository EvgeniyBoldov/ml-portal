# Example test environment configuration
# Copy to .env.test.local and fill in your actual tokens

# =============================================================================
# Database (test containers)
# =============================================================================
DATABASE_URL=postgresql://ml_portal:ml_portal_password@localhost:5433/ml_portal_test

# =============================================================================
# Redis (test containers)
# =============================================================================
REDIS_URL=redis://localhost:6380/0
CELERY_BROKER_URL=redis://localhost:6380/0
CELERY_RESULT_BACKEND=redis://localhost:6380/1

# =============================================================================
# LLM Configuration (Groq)
# Get your API key: https://console.groq.com/keys
# =============================================================================
GROQ_API_KEY=gsk_your_groq_api_key_here
LLM_PROVIDER=groq
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_DEFAULT_MODEL=llama-3.3-70b-versatile
LLM_TIMEOUT=60

# =============================================================================
# Netbox Configuration
# Token expires daily! Get new token at: https://demo.netbox.dev/user/api-tokens/
# =============================================================================
NETBOX_URL=https://demo.netbox.dev/
NETBOX_API_TOKEN=your_netbox_token_here

# =============================================================================
# Default Admin (auto-created by migration 0144)
# =============================================================================
DEFAULT_ADMIN_LOGIN=admin
DEFAULT_ADMIN_PASSWORD=admin123

# =============================================================================
# S3 (Minio for tests)
# =============================================================================
S3_ENDPOINT=http://localhost:9002
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET_RAG=rag_test

# =============================================================================
# Qdrant (test container)
# =============================================================================
QDRANT_URL=http://localhost:6334

# =============================================================================
# JWT
# =============================================================================
JWT_SECRET=test-jwt-secret-minimum-256-bits-for-testing

# =============================================================================
# Environment
# =============================================================================
ENVIRONMENT=test
DEBUG=true
